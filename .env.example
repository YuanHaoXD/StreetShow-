# =============================================
# StreetShow 环境变量配置模板
# 复制此文件为 .env，然后填入真实密钥
# =============================================

# DMXAPI 统一密钥（视觉分析 + 图像生成共用同一个 Key）
# 在 https://www.dmxapi.cn 获取
DMXAPI_KEY=

# 可选配置（以下均有默认值，按需修改）
# DMXAPI_VL_MODEL=qwen3.5-flash       # 视觉分析模型
# DMXAPI_TIMEOUT=90                   # API 请求超时（秒）
# MAX_CONCURRENT=2                    # 最大并发请求数
# MAX_UPLOAD_MB=10                    # 上传图片大小限制（MB）
# MAX_IMAGE_EDGE=2048                 # 图片最长边限制（px）
# LOG_LEVEL=INFO
# CORS_ALLOW_ORIGINS=*
# ASSET_TTL_SECONDS=3600
# JOB_TTL_SECONDS=3600
